{
  "name": "@citizens-wear/connect-client",
  "version": "0.0.0",
  "private": true,
  "description": "Citizens Connect integration contract and mock client for Citizens Wear",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mock": "./src/mock/index.ts",
    "./fixtures": "./src/fixtures/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@citizens-wear/config": "workspace:*",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "typescript": "5.5.4",
    "vitest": "3.2.4"
  }
}
