{
  "name": "@citizens-wear/db",
  "version": "0.0.0",
  "private": true,
  "description": "Citizens Wear data model — Prisma schema + in-memory WearStore used until a real DB lands.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./memory": "./src/memory.ts"
  },
  "files": [
    "src",
    "prisma"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@citizens-wear/connect-client": "workspace:*"
  },
  "devDependencies": {
    "@citizens-wear/config": "workspace:*",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "typescript": "5.5.4",
    "vitest": "3.2.4"
  }
}
