// Citizens Wear data model — Phase 2.
//
// This file is the reference source-of-truth for Wear-owned data. It is not
// yet wired to a runtime (`prisma generate` / `prisma migrate`) — that lands
// with Phase 3, when Citizens Connect is also wired for real. Until then,
// `packages/db/src/memory.ts` provides an in-memory store with the same
// shape, used by the app and by contract tests.
//
// Ownership:
//   - `User` and `Brand` mirror identities from Citizens Connect. Connect is
//     the source of truth; Wear stores only the Connect id plus a local
//     `Profile` row for Wear-specific state (visibility, bio, etc.).
//   - `Profile`, `Follow`, and `UserSettings` are Wear-owned.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Mirror of a Citizens Connect citizen. Connect owns `handle`, `displayName`,
/// `email`, and `avatarUrl`; Wear stores them denormalised for fast reads and
/// reconciles via the Connect event bus.
model User {
  id           String   @id // Connect id, e.g. "usr_001"
  handle       String   @unique
  displayName  String
  email        String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  settings     UserSettings?
  followers    Follow[]  @relation("FollowTarget")
  following    Follow[]  @relation("FollowActor")
  ownedBrands  Brand[]   @relation("BrandOwner")
  authoredPosts Post[]   @relation("PostAuthor")
  likes        Like[]
  comments     Comment[]
  commentLikes CommentLike[]
  saveCollections SaveCollection[]
}

/// Mirror of a Citizens Connect brand.
model Brand {
  id           String   @id // Connect id, e.g. "brd_001"
  slug         String   @unique
  name         String
  tagline      String?
  websiteUrl   String?
  logoUrl      String?
  verified     Boolean  @default(false)
  ownerUserId  String
  owner        User     @relation("BrandOwner", fields: [ownerUserId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]   @relation("PostBrand")
}

/// Wear-specific profile state attached to a `User`.
model Profile {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?
  visibility   ProfileVisibility @default(PUBLIC)
  /// Wear-side verified flag. Distinct from `Brand.verified`: this marks a
  /// citizen as a recognised Kingdom figure inside Wear (e.g. pastor, leader).
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

/// Follow edge. `(actorId, targetId)` is unique; self-follows are disallowed
/// at the application layer.
model Follow {
  actorId      String
  targetId     String
  actor        User     @relation("FollowActor", fields: [actorId], references: [id], onDelete: Cascade)
  target       User     @relation("FollowTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@id([actorId, targetId])
  @@index([targetId])
}

/// Per-user settings skeleton. Phase 2 lands only visibility + display name
/// overrides; notification/privacy surfaces land with Phase 7.
model UserSettings {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayNameOverride String?
  profileVisibility  ProfileVisibility @default(PUBLIC)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ────────────────────────────────────────────────────────────────────────
// Phase 4 — posts, media, likes, comments, saves.
// ────────────────────────────────────────────────────────────────────────

/// Social post authored by a citizen, optionally published *as* a brand.
/// `taggedProductIds` is a denormalised array of Connect product ids so
/// the brand composer can tag drops without a join table.
model Post {
  id                String   @id
  authorId          String
  author            User     @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  brandId           String?
  brand             Brand?   @relation("PostBrand", fields: [brandId], references: [id], onDelete: SetNull)
  body              String
  taggedProductIds  String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  media             PostMedia[]
  likes             Like[]
  comments          Comment[]
  saves             SavedPost[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([brandId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

enum PostMediaKind {
  IMAGE
  VIDEO
}

model PostMedia {
  id         String        @id
  postId     String
  post       Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  url        String
  kind       PostMediaKind @default(IMAGE)
  altText    String?
  orderIndex Int           @default(0)

  @@index([postId, orderIndex])
}

model Like {
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([postId, userId])
  @@index([userId, createdAt(sort: Desc)])
}

model Comment {
  id               String    @id
  postId           String
  post             Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId         String
  author           User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentCommentId  String?
  parent           Comment?  @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies          Comment[] @relation("CommentThread")
  body             String
  createdAt        DateTime  @default(now())

  likes            CommentLike[]

  @@index([postId, createdAt])
  @@index([authorId, createdAt(sort: Desc)])
}

model CommentLike {
  commentId String
  userId    String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([commentId, userId])
}

/// A user-owned save collection. Every user gets an implicit "default"
/// collection on first save; named collections land with Phase 7.
model SaveCollection {
  id        String       @id
  ownerId   String
  owner     User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime     @default(now())
  posts     SavedPost[]

  @@unique([ownerId, name])
}

model SavedPost {
  collectionId String
  postId       String
  collection   SaveCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  post         Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())

  @@id([collectionId, postId])
  @@index([postId])
}

// ────────────────────────────────────────────────────────────────────────
// Phase 6 — stories, direct messages, blocks, reports.
// ────────────────────────────────────────────────────────────────────────

enum StoryMediaKind {
  IMAGE
  VIDEO
  TEXT
}

enum StoryAudience {
  PUBLIC
  FOLLOWERS
}

/// A 24-hour ephemeral story authored by a citizen, optionally as a brand.
/// `expiresAt` is materialised at creation time so retention/cleanup jobs
/// can index on it without recomputing.
model Story {
  id          String         @id
  authorId    String
  brandId     String?
  mediaUrl    String?
  mediaKind   StoryMediaKind @default(IMAGE)
  caption     String?
  audience    StoryAudience  @default(PUBLIC)
  createdAt   DateTime       @default(now())
  expiresAt   DateTime

  views       StoryView[]
  reactions   StoryReaction[]
  highlights  StoryHighlightItem[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model StoryView {
  storyId  String
  viewerId String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, viewerId])
  @@index([viewerId, viewedAt(sort: Desc)])
}

enum StoryReactionKind {
  AMEN
  LOVE
  FIRE
  PRAY
  CROWN
}

model StoryReaction {
  id        String            @id
  storyId   String
  userId    String
  kind      StoryReactionKind
  createdAt DateTime          @default(now())
  story     Story             @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt(sort: Desc)])
}

/// Author-curated long-lived collection of stories surfaced on a profile.
model StoryHighlight {
  id        String               @id
  ownerId   String
  name      String
  coverUrl  String?
  createdAt DateTime             @default(now())
  items     StoryHighlightItem[]

  @@index([ownerId, createdAt(sort: Desc)])
}

model StoryHighlightItem {
  highlightId String
  storyId     String
  orderIndex  Int            @default(0)
  highlight   StoryHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  story       Story          @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([highlightId, storyId])
  @@index([highlightId, orderIndex])
}

enum ConversationKind {
  DIRECT
  GROUP
}

enum ConversationRequestState {
  REQUESTED
  ACCEPTED
}

enum ConversationMemberRole {
  OWNER
  MEMBER
}

/// A direct or group conversation. `name` is null for 1:1 DMs.
model Conversation {
  id           String                @id
  kind         ConversationKind      @default(DIRECT)
  name         String?
  createdById  String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  members      ConversationMember[]
  messages     Message[]

  @@index([updatedAt(sort: Desc)])
}

model ConversationMember {
  conversationId String
  userId         String
  joinedAt       DateTime                 @default(now())
  lastReadAt     DateTime?
  mutedUntil     DateTime?
  requestState   ConversationRequestState @default(ACCEPTED)
  role           ConversationMemberRole   @default(MEMBER)
  conversation   Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, requestState])
}

model Message {
  id             String       @id
  conversationId String
  authorId       String
  body           String
  createdAt      DateTime     @default(now())
  deletedAt      DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([authorId, createdAt(sort: Desc)])
}

/// Symmetric-effect block: if either side has a Block edge, neither can DM,
/// see stories of, or interact with the other.
model Block {
  actorId   String
  targetId  String
  createdAt DateTime @default(now())

  @@id([actorId, targetId])
  @@index([targetId])
}

enum ReportSubjectKind {
  POST
  COMMENT
  MESSAGE
  STORY
  USER
}

enum ReportReason {
  SPAM
  ABUSE
  SEXUAL
  SELF_HARM
  ILLEGAL
  OTHER
}

/// Open-ended report queue; moderation tooling lands with Phase 9.
model Report {
  id          String            @id
  reporterId  String
  subjectKind ReportSubjectKind
  subjectId   String
  reason      ReportReason
  note        String?
  createdAt   DateTime          @default(now())

  @@index([subjectKind, subjectId])
  @@index([reporterId, createdAt(sort: Desc)])
}
