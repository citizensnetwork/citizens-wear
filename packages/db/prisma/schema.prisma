// Citizens Wear data model — Phase 2.
//
// This file is the reference source-of-truth for Wear-owned data. It is not
// yet wired to a runtime (`prisma generate` / `prisma migrate`) — that lands
// with Phase 3, when Citizens Connect is also wired for real. Until then,
// `packages/db/src/memory.ts` provides an in-memory store with the same
// shape, used by the app and by contract tests.
//
// Ownership:
//   - `User` and `Brand` mirror identities from Citizens Connect. Connect is
//     the source of truth; Wear stores only the Connect id plus a local
//     `Profile` row for Wear-specific state (visibility, bio, etc.).
//   - `Profile`, `Follow`, `UserSettings`, posts, engagement, cart intent,
//     brand follows, and moderation state are Wear-owned.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Mirror of a Citizens Connect citizen. Connect owns `handle`, `displayName`,
/// `email`, and `avatarUrl`; Wear stores them denormalised for fast reads and
/// reconciles via the Connect event bus.
model User {
  id           String   @id // Connect id, e.g. "usr_001"
  handle       String   @unique
  displayName  String
  email        String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  settings     UserSettings?
  followers    Follow[]  @relation("FollowTarget")
  following    Follow[]  @relation("FollowActor")
  ownedBrands  Brand[]   @relation("BrandOwner")
  posts        Post[]    @relation("PostAuthor")
  postLikes    PostLike[] @relation("PostLikeActor")
  comments     PostComment[] @relation("CommentAuthor")
  savedPosts   SavedPost[]
  cartItems    CartItem[]
  brandFollows BrandFollow[]
  reportedModerationItems ModerationItem[] @relation("ModerationReporter")
  reviewedModerationItems ModerationItem[] @relation("ModerationReviewer")
}

/// Mirror of a Citizens Connect brand.
model Brand {
  id           String   @id // Connect id, e.g. "brd_001"
  slug         String   @unique
  name         String
  tagline      String?
  websiteUrl   String?
  logoUrl      String?
  verified     Boolean  @default(false)
  ownerUserId  String
  owner        User     @relation("BrandOwner", fields: [ownerUserId], references: [id])
  posts        Post[]   @relation("BrandPosts")
  followers    BrandFollow[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Wear-specific profile state attached to a `User`.
model Profile {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?
  visibility   ProfileVisibility @default(PUBLIC)
  /// Wear-side verified flag. Distinct from `Brand.verified`: this marks a
  /// citizen as a recognised Kingdom figure inside Wear (e.g. pastor, leader).
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

enum PostAuthorKind {
  CITIZEN
  BRAND
}

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  HIDDEN
  REJECTED
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS
}

enum CommentStatus {
  VISIBLE
  HIDDEN
}

enum ModerationTargetType {
  POST
  COMMENT
  CREATOR_SUBMISSION
}

enum ModerationStatus {
  OPEN
  APPROVED
  REJECTED
  HIDDEN
}

/// Follow edge. `(actorId, targetId)` is unique; self-follows are disallowed
/// at the application layer.
model Follow {
  actorId      String
  targetId     String
  actor        User     @relation("FollowActor", fields: [actorId], references: [id], onDelete: Cascade)
  target       User     @relation("FollowTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@id([actorId, targetId])
  @@index([targetId])
}

/// Per-user settings skeleton. Phase 2 lands only visibility + display name
/// overrides; notification/privacy surfaces land with Phase 7.
model UserSettings {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayNameOverride String?
  profileVisibility  ProfileVisibility @default(PUBLIC)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Wear-owned social post. `brandId` and product tags point to Connect-owned
/// catalog records; Wear stores references only. Application invariant:
/// `authorKind` is `BRAND` iff `brandId` is present.
model Post {
  id            String      @id
  authorUserId  String
  author        User        @relation("PostAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  authorKind    PostAuthorKind
  brandId       String?
  brand         Brand?      @relation("BrandPosts", fields: [brandId], references: [id], onDelete: Restrict)
  caption       String
  status        PostStatus  @default(PUBLISHED)
  visibility    PostVisibility @default(PUBLIC)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  publishedAt   DateTime?

  media         PostMedia[]
  productTags   PostProductTag[]
  likes         PostLike[]
  comments      PostComment[]
  saves         SavedPost[]

  @@index([authorUserId, createdAt])
  @@index([brandId, createdAt])
  @@index([status, publishedAt])
}

model PostMedia {
  id        String   @id
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  altText   String
  sortOrder Int      @default(0)

  @@index([postId, sortOrder])
}

/// Product tags reference Connect product ids; there is no local Product table.
model PostProductTag {
  postId    String
  productId String
  sortOrder Int    @default(0)
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, productId])
  @@index([productId])
}

model PostLike {
  postId      String
  actorUserId String
  createdAt   DateTime @default(now())
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  actor       User     @relation("PostLikeActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@id([postId, actorUserId])
  @@index([actorUserId])
}

model PostComment {
  id           String   @id
  postId       String
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorUserId String
  author       User     @relation("CommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  body         String
  status       CommentStatus @default(VISIBLE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([authorUserId])
}

model SavedPost {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

/// Cart intent only. Payment, orders, and fulfilment are deferred.
model CartItem {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId])
}

model BrandFollow {
  userId    String
  brandId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([userId, brandId])
  @@index([brandId])
}

model ModerationItem {
  id             String   @id
  targetType     ModerationTargetType
  targetId       String
  reporterUserId String?
  reporter       User?    @relation("ModerationReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  reviewerUserId String?
  reviewer       User?    @relation("ModerationReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  status         ModerationStatus @default(OPEN)
  reason         String
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  resolvedAt     DateTime?

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterUserId])
  @@index([reviewerUserId])
}
