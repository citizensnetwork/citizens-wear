{
  "name": "@citizens-wear/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:frontend": "python -m http.server 3001 --directory src/frontend",
    "build": "node scripts/build-frontend.js && next build",
    "build:frontend": "node scripts/build-frontend.js",
    "build:mobile": "node scripts/build-frontend.js --mobile",
    "start": "next start -p 3000",
    "lint": "next lint --dir src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@citizens-wear/connect-client": "workspace:*",
    "@citizens-wear/db": "workspace:*",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "next": "15.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@citizens-wear/config": "workspace:*",
    "@citizens/frontend-build": "workspace:*",
    "@types/node": "26.1.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitest/coverage-v8": "3.2.4",
    "esbuild": "^0.25.0",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.15",
    "eslint-config-prettier": "9.1.0",
    "typescript": "5.5.4",
    "vitest": "3.2.4"
  }
}
